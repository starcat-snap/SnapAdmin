        <service id="SnapAdmin\Core\System\Country\Aggregate\CountryState\CountryStateDefinition">
            <tag name="snap.entity.definition"/>
        </service>
        <service id="SnapAdmin\Core\System\Country\Aggregate\CountryStateTranslation\CountryStateTranslationDefinition">
