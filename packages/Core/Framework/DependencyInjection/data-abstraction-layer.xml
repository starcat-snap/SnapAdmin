            <argument type="service" id="SnapAdmin\Core\Framework\DataAbstractionLayer\DefinitionInstanceRegistry"/>
            <argument type="service" id="SnapAdmin\Core\Framework\DataAbstractionLayer\Write\EntityWriteResultFactory"/>
