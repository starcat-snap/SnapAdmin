<div class="sw-help-center">
    <button
        class="sw-help-center__button"
        :aria-label="$tc('help-center.sidebar.ariaLabelButtonOpen')"
        @click="openHelpSidebar"
    >
        <sw-tabler-icon
            name="help"
            size="24px"
        />
    </button>

    <sw-help-sidebar
        v-if="showHelpSidebar"
        ref="helpSidebar"
    />

    <sw-shortcut-overview
        ref="shortcutModal"
        @shortcut-open="openShortcutModal"
        @shortcut-close="closeShortcutModal"
    />
</div>
