<!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
{% block sw_desktop %}
    <div
        class="sw-desktop"
        :class="desktopClasses"
    >

        <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
        {% block sw_desktop_sidebar %}
            <sw-admin-menu v-if="!noNavigation"/>
        {% endblock %}

        <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
        {% block sw_desktop_content %}
            <div class="sw-desktop__content">
                {% block sw_desktop_content_header %}
                    <div v-if="!noTopbar" class="sw-desktop__content_header">
                        {% block sw_desktop_content_header_left %}
                            <div class="sw-desktop__content_header_left">
                                {% block sw_desktop_content_header_left_menu_toggle_sidebar_icon %}
                                    {#                                    <sw-icon #}
                                    {#                                        name="baseline-density-small" #}

                                    {#                                    /> #}
                                {% endblock %}
                            </div>
                        {% endblock %}
                        {% block sw_desktop_content_header_center %}
                            <div class="sw-desktop__content_header_center"></div>
                        {% endblock %}
                        {% block sw_desktop_content_header_right %}
                            <div class="sw-desktop__content_header_right">

                                {% block sw_desktop_content_header_right_notification_center %}
                                    <div class="action-link"><sw-notification-center/></div>
                                {% endblock %}

                                {% block sw_desktop_content_header_right_help %}
                                    <div class="action-link"><sw-help-center-v2 /></div>
                                {% endblock %}
                            </div>
                        {% endblock %}
                    </div>
                {% endblock %}
                <!-- eslint-disable-next-line sw-deprecation-rules/no-twigjs-blocks -->
                {% block sw_desktop_content_view %}
                    <div class="sw-desktop__content_view">
                        <sw-error-boundary>
                            <router-view/>
                        </sw-error-boundary>
                    </div>
                {% endblock %}
            </div>
            <sw-app-app-url-changed-modal
                v-if="urlDiff !== null"
                :url-diff="urlDiff"
                @modal-close="closeModal"
            />
        {% endblock %}
    </div>
{% endblock %}
